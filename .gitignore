# --- Training-side data and model artifacts (bootstrap documented in
# README). NEVER add /artifacts/ here (below) — that is the committed
# runtime tree a deployed API/dashboard needs; these are the training-only
# trees that stay local.
/data/
/data_hidden_tmp/
/models/

# --- Weekly ingestion inspection report (scripts/ingest_jolpica.py's
# write_ingest_report) — ephemeral per-run diagnostic uploaded as a CI
# artifact (retrain.yml), never committed.
/ingest_report/

# --- MLflow local tracking store
mlruns/
mlflow.db

# --- Environment / secrets
.env

# --- Python build & cache
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- Test & tooling caches
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.ruff_cache/

# --- Local dev-launcher logs (scripts/dev.py)
/logs/

# --- Jupyter
.ipynb_checkpoints/

# --- Internal engineering notes (machine-local; not part of the public project)
.ai/
.claude/
.agents/
/context/
/reports/