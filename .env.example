# Template only — copy to .env and edit; .env itself is gitignored, never
# committed (see app/config.py's docstring: every setting is F1_-prefixed
# and environment-driven, no hardcoded paths in app code).
#
# Used two ways:
#   1. Local (non-Docker) dev: python-dotenv-style `.env` loaded by
#      pydantic-settings (Settings.model_config, app/config.py).
#   2. Docker Compose: values here are picked up automatically by Compose's
#      own `${VAR:-default}` substitution in docker-compose.yml /
#      docker-compose.override.yml if a `.env` file exists next to them —
#      Compose reads project-root `.env` for this purpose without any
#      extra `env_file:` directive.
#
# Every setting has a working default (see app/config.py) — you only need
# entries here for what you're actually changing.

# --- app/config.py Settings (F1_ prefix) --------------------------------

# Where the API lives, from the DASHBOARD's point of view. Non-Docker local
# dev only — docker-compose.yml hardcodes this to http://api:8000 for the
# containerized dashboard, since it must always point at the sibling `api`
# service, never an operator-supplied value.
# F1_API_URL=http://localhost:8000

# Newest season verified for historical serving (Decision 050). 2025-2026
# rows exist but come from an unverified upstream source; do not raise this
# without a decision recording how that provenance was verified — see
# docs/serving_policy.md. Distinct from the (separately fixed) evaluation
# holdout and unaffected upcoming-race prediction path — see that doc.
# F1_VERIFIED_SEASONS_THROUGH=2024

# Enables GET /api/v1/debug/features/{race_id}. Keep false/unset in any
# shared or production environment.
# F1_DEBUG_ENDPOINTS=false

# Comma-separated allowed CORS origins, or "*" for any. Empty (default)
# means no cross-origin browser access.
# F1_CORS_ALLOW_ORIGINS=

# F1_PREDICTION_CACHE_SIZE=512
# F1_LOG_LEVEL=INFO

# Override only if you need artifacts/ or data/ at a non-default location
# (e.g. pointing data_dir at the full local data/ tree instead of the
# committed artifacts/display/ subset — see app/config.py).
# F1_SERVING_BUNDLE_PATH=artifacts/serving/staging
# F1_FEATURES_PATH=artifacts/features.parquet
# F1_DATA_DIR=artifacts/display

# --- Docker Compose only (docker-compose.yml) ---------------------------

# API_PORT=8000
# DASHBOARD_PORT=8501
# TAG=latest
